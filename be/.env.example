# Database
DATABASE_URL="postgresql://postgres:postgres123@localhost:5432/evn_market?schema=public"

# Application
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=evn-market-super-secret-key-2025
JWT_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Facebook OAuth
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_CALLBACK_URL=http://localhost:3000/auth/facebook/callback

# Cors
CORS_ORIGIN=http://localhost:3001

# SMTP (Transactional Email)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL="EVN Market <no-reply@evn-market.com>"

# Password Reset Configuration
PASSWORD_RESET_OTP_TTL_MINUTES=10
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
PASSWORD_RESET_MAX_ATTEMPTS=5
PASSWORD_RESET_RESEND_INTERVAL_SECONDS=60
PASSWORD_RESET_MAX_RESENDS=3

# VNPay
VNPAY_TMN_CODE=your-vnpay-tmn-code
VNPAY_HASH_SECRET=your-vnpay-hash-secret
VNPAY_RETURN_URL=http://localhost:3001/payments/vnpay/return
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_DEFAULT_ORDER_TYPE=other
VNPAY_LOCALE=vn